class Consulta {
    Paciente paciente;
    Profissional profissional;
    String especialidade;
    String data;
    String horario;
    String tipo;
    String status;
    double multa;

    Consulta(Paciente paciente, Profissional profissional, String data, String horario) {
        this.paciente = paciente;
        this.profissional = profissional;
        this.data = data;
        this.horario = horario;
        this.status = "Agendada";
        this.multa = 0;
    }

    Consulta(Paciente paciente, Profissional profissional, String data, String horario, String tipo) {
        this.paciente = paciente;
        this.profissional = profissional;
        this.data = data;
        this.horario = horario;
        this.tipo = tipo;
        this.status = "Agendada";
        this.multa = 0;
    }

    void agendarConsulta() {
        if (paciente.ativo) {
            status = "Agendada";
            System.out.println("Consulta agendada com sucesso!");
        } else {
            System.out.println("Paciente inativo não pode agendar.");
        }
    }

    void cancelarConsulta() {
        status = "Cancelada";
        System.out.println("Consulta cancelada.");
    }

    void cancelarConsulta(double multa) {
        status = "Cancelada";
        this.multa = multa;
        System.out.println("Consulta cancelada com multa de R$" + multa);
    }

    void remarcarConsulta(String novaData) {
        this.data = novaData;
        System.out.println("Consulta remarcada para: " + novaData);
    }

    void remarcarConsulta(String novaData, String novoHorario) {
        this.data = novaData;
        this.horario = novoHorario;
        System.out.println("Consulta remarcada para: " + novaData + " às " + novoHorario);
    }

    void exibirConsulta() {
        System.out.println("Paciente: " + paciente.nome);
        System.out.println("Profissional: " + profissional.nome);
        System.out.println("Data: " + data);
        System.out.println("Horário: " + horario);
        System.out.println("Tipo: " + tipo);
        System.out.println("Status: " + status);
    }
}

