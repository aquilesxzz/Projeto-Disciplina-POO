import java.util.Scanner;

class Paciente {
    String nome;
    String cpf;
    int idade;
    String telefone;
    String convenio;
    boolean ativo;

    // Construtor simples
    Paciente(String nome, String cpf) {
        this.nome = nome;
        this.cpf = cpf;
        this.ativo = true;
    }

    // Sobrecarga de construtor
    Paciente(String nome, String cpf, int idade, String telefone) {
        this.nome = nome;
        this.cpf = cpf;
        this.idade = idade;
        this.telefone = telefone;
        this.ativo = true;
    }

    // Sobrecarga de construtor
    Paciente(String nome, String cpf, int idade, String telefone, String convenio) {
        this.nome = nome;
        this.cpf = cpf;
        this.idade = idade;
        this.telefone = telefone;
        this.convenio = convenio;
        this.ativo = true;
    }

    void complementarCadastro(int idade, String telefone) {
        this.idade = idade;
        this.telefone = telefone;
    }

    void complementarCadastro(int idade, String telefone, String convenio) {
        this.idade = idade;
        this.telefone = telefone;
        this.convenio = convenio;
    }

    void desativarPaciente() {
        ativo = false;
    }

    void exibirPaciente() {
        System.out.println("Nome: " + nome);
        System.out.println("CPF: " + cpf);
        System.out.println("Idade: " + idade);
        System.out.println("Telefone: " + telefone);
        System.out.println("Convênio: " + convenio);
        System.out.println("Ativo: " + ativo);
    }
}

