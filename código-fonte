class Pagamento {
    double valor;
    String tipoPagamento;
    int parcelas;
    double valorParcela;

    Pagamento(double valor, String tipoPagamento) {
        this.valor = valor;
        this.tipoPagamento = tipoPagamento;
        this.parcelas = 1;
    }

    Pagamento(double valor, String tipoPagamento, int parcelas) {
        this.valor = valor;
        this.tipoPagamento = tipoPagamento;
        this.parcelas = parcelas;
    }

    void calcularPagamento(double valorBase) {
        this.valor = valorBase;
    }

    void calcularPagamento(double valorBase, double desconto) {
        this.valor = valorBase - desconto;
    }

    void calcularPagamento(double valorBase, double desconto, double multa) {
        this.valor = valorBase - desconto + multa;
    }

    void exibirPagamento() {
        System.out.println("Valor total: R$" + valor);
        System.out.println("Tipo de pagamento: " + tipoPagamento);
        System.out.println("Parcelas: " + parcelas);
    }
}

